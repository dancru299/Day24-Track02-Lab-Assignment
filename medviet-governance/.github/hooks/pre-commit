#!/bin/bash
# Pre-commit hook: run security checks before committing.

set -u

PROJECT_DIR="."
if [ ! -d "$PROJECT_DIR/src" ] && [ -d "medviet-governance/src" ]; then
    PROJECT_DIR="medviet-governance"
fi

echo "Running security checks..."

# 1. git-secrets scan when installed; otherwise run a local fallback regex scan.
if git secrets --help >/dev/null 2>&1; then
    git secrets --pre_commit_hook -- "$@"
    if [ $? -ne 0 ]; then
        echo "git-secrets found potential secrets. Commit blocked."
        exit 1
    fi
else
    echo "git-secrets not found; running fallback staged-file secret scan."
    SECRET_PATTERN='AWS_SECRET_ACCESS_KEY|AWS_SECRET_KEY|AKIA[0-9A-Z]{16}|CCCD[[:space:]:]+[0-9]{12}|cccd[[:space:]:]+[0-9]{12}|password[[:space:]]*=[[:space:]]*["'"'"'][^"'"'"']+["'"'"']|secret_key[[:space:]]*=[[:space:]]*["'"'"'][^"'"'"']+["'"'"']'
    failed=0
    while IFS= read -r file; do
        if [ "$file" = "medviet-governance/.github/hooks/pre-commit" ] || [ "$file" = ".github/hooks/pre-commit" ]; then
            continue
        fi
        if git show ":$file" 2>/dev/null | grep -nE "$SECRET_PATTERN" >/tmp/precommit_secret_match.txt; then
            echo "Potential secret found in staged file: $file"
            cat /tmp/precommit_secret_match.txt
            failed=1
        fi
    done < <(git diff --cached --name-only --diff-filter=ACM)

    rm -f /tmp/precommit_secret_match.txt
    if [ "$failed" -ne 0 ]; then
        echo "Fallback secret scan found potential secrets. Commit blocked."
        exit 1
    fi
fi

# 2. Bandit SAST scan.
echo "Running Bandit SAST..."
if command -v bandit >/dev/null 2>&1; then
    bandit -r "$PROJECT_DIR/src" -ll -q
elif command -v python >/dev/null 2>&1; then
    python -m bandit -r "$PROJECT_DIR/src" -ll -q
elif command -v python3 >/dev/null 2>&1 && python3 -m bandit --version >/dev/null 2>&1; then
    python3 -m bandit -r "$PROJECT_DIR/src" -ll -q
elif command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass \
        -Command "bandit -r '$PROJECT_DIR/src' -ll -q"
else
    echo "Bandit is not available in PATH."
    exit 1
fi
if [ $? -ne 0 ]; then
    echo "Bandit found security issues. Review the output above."
    exit 1
fi

# 3. pip-audit dependency check.
echo "Checking dependencies for CVEs..."
if command -v pip-audit >/dev/null 2>&1; then
    pip-audit -r "$PROJECT_DIR/requirements.txt" --desc on
elif command -v python >/dev/null 2>&1; then
    python -m pip_audit -r "$PROJECT_DIR/requirements.txt" --desc on
elif command -v python3 >/dev/null 2>&1 && python3 -m pip_audit --version >/dev/null 2>&1; then
    python3 -m pip_audit -r "$PROJECT_DIR/requirements.txt" --desc on
elif command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass \
        -Command "pip-audit -r '$PROJECT_DIR/requirements.txt' --desc on"
else
    echo "pip-audit is not available in PATH."
    exit 1
fi
if [ $? -ne 0 ]; then
    echo "Vulnerable dependencies found. Update before committing."
    exit 1
fi

echo "All security checks passed."
exit 0
